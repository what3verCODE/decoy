{
  "name": "decoy-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A fast, contract-first HTTP mock you point a base URL at.",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "prepare": "pnpm run build",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm -r --if-present run test:e2e",
    "typecheck": "pnpm -r run typecheck",
    "docs:build": "pnpm --filter @decoy/docs run build",
    "docs:dev": "pnpm --filter @decoy/docs run dev",
    "check": "biome check . && pnpm --filter @decoy/core-purity run guard",
    "fix": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@rslib/core": "^0.22.1",
    "@rstest/core": "^0.10.4",
    "@types/node": "^24.0.0",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3"
  }
}
