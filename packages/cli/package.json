{
  "name": "@decoy/cli",
  "version": "0.0.0",
  "description": "The `decoy` CLI: boots a Decoy server from a config (decoy start).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "decoy": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "rstest run",
    "typecheck": "tsc -p tsconfig.lint.json"
  },
  "dependencies": {
    "@decoy/config": "workspace:*",
    "@decoy/core": "workspace:*",
    "@decoy/server": "workspace:*"
  },
  "devDependencies": {
    "@decoy/ui": "workspace:*",
    "@types/node": "^24.0.0"
  }
}
