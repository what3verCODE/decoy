{
  "name": "@decoy/core",
  "version": "0.0.0",
  "description": "Decoy's pure engine: match(request, selection) → response, types, path matching. Zero IO.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@jmespath-community/jmespath": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "test": "rstest run",
    "typecheck": "tsc -p tsconfig.lint.json"
  }
}
