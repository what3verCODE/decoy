{
  "name": "@decoy/nest",
  "version": "0.0.0",
  "description": "Decoy NestJS module: embed the in-process engine for partial mocking — matched routes are served from mocks, unmatched requests fall through to the host app.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "rstest run",
    "typecheck": "tsc -p tsconfig.lint.json"
  },
  "dependencies": {
    "@decoy/config": "workspace:*",
    "@decoy/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "supertest": "^7.0.0"
  }
}
