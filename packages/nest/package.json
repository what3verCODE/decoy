{
  "name": "@decoy/nest",
  "version": "0.0.0",
  "description": "Decoy NestJS module: embed the in-process engine for partial mocking — matched routes are served from mocks, unmatched requests fall through to the host app.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "rstest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@decoy/config": "workspace:*",
    "@decoy/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
