{
  "name": "@decoy/ui",
  "version": "0.0.0",
  "description": "Decoy web control panel: prebuilt Preact + signals SPA assets served by `decoy start --ui`. Static assets only — no server.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./node/index.ts",
      "types": "./node/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build && rsbuild build",
    "dev": "rsbuild dev",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.client.json"
  },
  "devDependencies": {
    "@decoy/config": "workspace:*",
    "@decoy/core": "workspace:*",
    "@decoy/playwright": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@preact/signals": "^2.9.1",
    "@rsbuild/core": "^2.0.0",
    "@rsbuild/plugin-preact": "^2.0.0",
    "@rslib/core": "^0.22.1",
    "@types/node": "^24.0.0",
    "@unocss/postcss": "^66.7.2",
    "postcss": "^8.5.15",
    "preact": "^10.29.2",
    "unocss": "^66.7.2"
  }
}
