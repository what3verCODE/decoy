{
  "name": "@decoy/ui",
  "version": "0.0.0",
  "description": "Decoy web control panel.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./node/index.ts",
      "types": "./node/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build && rsbuild build",
    "dev": "pnpm run \"/^dev:/\"",
    "dev:client": "rsbuild dev",
    "dev:server": "decoy start",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.client.json"
  },
  "devDependencies": {
    "@decoy/cli": "workspace:*",
    "@decoy/config": "workspace:*",
    "@decoy/core": "workspace:*",
    "@decoy/playwright": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@rsbuild/core": "^2.0.0",
    "@rsbuild/plugin-preact": "^2.0.0",
    "@rslib/core": "^0.22.1",
    "@types/node": "^24.0.0",
    "@unocss/postcss": "^66.7.2",
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "patronum": "^2.3.0",
    "postcss": "^8.5.15",
    "preact": "^10.29.2",
    "unocss": "^66.7.2"
  }
}
