{
  // The Preact SPA. rsbuild bundles it into dist/client; tsc only type-checks it,
  // hence noEmit. jsxImportSource + the preact/compat aliases make React-typed libs
  // resolve against Preact.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["node"],
    "paths": {
      "react": ["../../node_modules/preact/compat/"],
      "react-dom": ["../../node_modules/preact/compat/"]
    }
  },
  "include": ["client"],
  "exclude": []
}
